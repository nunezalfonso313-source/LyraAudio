<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Cabecera -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#111111">

            <ImageView
                android:id="@+id/album_art"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:background="#222222"
                android:src="@android:drawable/ic_media_play"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/track_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cargando..."
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:ellipsize="marquee"
                    android:singleLine="true"/>

                <TextView
                    android:id="@+id/track_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#00BFFF"
                    android:textSize="13sp"
                    android:singleLine="true"/>

                <TextView
                    android:id="@+id/track_album"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:singleLine="true"/>

                <TextView
                    android:id="@+id/track_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#00FF00"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- VU Meters -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:orientation="horizontal"
            android:background="#0D0D0D"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <com.lyra.audiokernel.VUMeterView
                android:id="@+id/vu_left"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"/>

            <com.lyra.audiokernel.VUMeterView
                android:id="@+id/vu_right"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Nixie -->
        <com.lyra.audiokernel.NixieDisplayView
            android:id="@+id/nixie_display"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <!-- SeekBar -->
        <SeekBar
            android:id="@+id/seek_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:progressTint="#00BFFF"
            android:thumbTint="#00BFFF"/>

        <!-- Tiempos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/time_current"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textColor="#00FF00"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/track_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="#888888"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/time_total"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textColor="#00FF00"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Botones de control (YA CON LAYOUT_HEIGHT) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btn_shuffle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⇀"
                android:background="@android:color/transparent"
                android:textColor="#555555"/>

            <Button
                android:id="@+id/btn_prev"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏮"
                android:background="@android:color/transparent"
                android:textColor="#CCCCCC"/>

            <Button
                android:id="@+id/btn_play"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="▶"
                android:textColor="#00FF00"
                android:background="@android:color/transparent"
                android:textSize="22sp"/>

            <Button
                android:id="@+id/btn_next"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏭"
                android:background="@android:color/transparent"
                android:textColor="#CCCCCC"/>

            <Button
                android:id="@+id/btn_repeat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↺"
                android:background="@android:color/transparent"
                android:textColor="#555555"/>
        </LinearLayout>

        <!-- Spectrum -->
        <com.lyra.audiokernel.SpectrumView
            android:id="@+id/spectrum_view"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="4dp"/>

        <!-- EQ Panel -->
        <LinearLayout
            android:id="@+id/eq_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111111"
            android:padding="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Bandas EQ -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/eq_label0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="60Hz" android:textColor="#888888" android:textSize="10sp"/>
                    <SeekBar android:id="@+id/eq_band0" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="20" android:progress="10"/>
                    <TextView android:id="@+id/eq_val0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0dB" android:textColor="#00FF00" android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/eq_label1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="230Hz" android:textColor="#888888" android:textSize="10sp"/>
                    <SeekBar android:id="@+id/eq_band1" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="20" android:progress="10"/>
                    <TextView android:id="@+id/eq_val1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0dB" android:textColor="#00FF00" android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/eq_label2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="910Hz" android:textColor="#888888" android:textSize="10sp"/>
                    <SeekBar android:id="@+id/eq_band2" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="20" android:progress="10"/>
                    <TextView android:id="@+id/eq_val2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0dB" android:textColor="#00FF00" android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/eq_label3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3.6kHz" android:textColor="#888888" android:textSize="10sp"/>
                    <SeekBar android:id="@+id/eq_band3" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="20" android:progress="10"/>
                    <TextView android:id="@+id/eq_val3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0dB" android:textColor="#00FF00" android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:id="@+id/eq_label4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="14kHz" android:textColor="#888888" android:textSize="10sp"/>
                    <SeekBar android:id="@+id/eq_band4" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="20" android:progress="10"/>
                    <TextView android:id="@+id/eq_val4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0dB" android:textColor="#00FF00" android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btn_eq_reset"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:text="RESET EQ"
                android:backgroundTint="#1A1A1A"
                android:textColor="#888888"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Search -->
        <LinearLayout
            android:id="@+id/search_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:padding="8dp">

            <EditText
                android:id="@+id/search_input"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="Buscar..."
                android:background="#1A1A1A"
                android:textColor="#FFFFFF"
                android:paddingStart="8dp"/>

            <Button
                android:id="@+id/btn_search_clear"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="✕"
                android:background="@android:color/transparent"
                android:textColor="#AAAAAA"/>
        </LinearLayout>

        <!-- Function Buttons (YA CON LAYOUT_HEIGHT) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp">

            <Button
                android:id="@+id/btn_eq"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EQ"
                android:backgroundTint="#1A1A1A"
                android:textColor="#CCCCCC"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btn_sort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AZ ARTISTA"
                android:backgroundTint="#1A1A1A"
                android:textColor="#CCCCCC"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btn_search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BUSCAR"
                android:backgroundTint="#1A1A1A"
                android:textColor="#CCCCCC"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btn_playlists"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PL"
                android:backgroundTint="#1A1A1A"
                android:textColor="#CCCCCC"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Playlist -->
        <TextView
            android:id="@+id/library_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LISTA DE REPRODUCCIÓN"
            android:textColor="#444444"
            android:textSize="10sp"
            android:paddingStart="12dp"
            android:paddingBottom="2dp"/>

        <ListView
            android:id="@+id/playlist_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#1A1A1A"
            android:dividerHeight="1dp"/>

    </LinearLayout>

    <!-- Drawer -->
    <LinearLayout
        android:id="@+id/pl_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/pl_drawer"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_gravity="bottom"
        android:background="#111111"
        android:visibility="gone"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/pl_name_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/pl_name_input"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="Nombre de playlist..."
                android:background="#1A1A1A"
                android:textColor="#FFFFFF"
                android:paddingStart="8dp"/>

            <Button
                android:id="@+id/btn_pl_save"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="OK"
                android:backgroundTint="#00FF00"
                android:textColor="#000000"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_pl_new"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+ NUEVA PLAYLIST"
                android:backgroundTint="#00FF00"
                android:textColor="#000000"/>

            <Button
                android:id="@+id/btn_pl_close"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="✕"
                android:background="@android:color/transparent"
                android:textColor="#AAAAAA"/>
        </LinearLayout>

        <ListView
            android:id="@+id/pl_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
